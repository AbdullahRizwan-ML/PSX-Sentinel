# ══════════════════════════════════════════════════════════════════════════════
# PSX Sentinel — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the required values.
# Never commit .env to version control.

# ── REQUIRED — Application will not start without these ──────────────────────

# PostgreSQL connection string (async driver)
# For Neon Cloud: postgresql+asyncpg://user:password@host.neon.tech/psx_sentinel?sslmode=require
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/psx_sentinel

# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32

# Groq API key — primary LLM provider (https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── OPTIONAL — Have sensible defaults ────────────────────────────────────────

# Google Gemini API key — fallback LLM provider (leave empty to disable)
GEMINI_API_KEY=

# CapitalStake API key — Pakistani financial data API (leave empty to disable)
CAPITALSTAKE_API_KEY=

# Redis connection URL
# For Upstash: rediss://default:password@your-endpoint.upstash.io:6379
REDIS_URL=redis://localhost:6379/0

# JWT algorithm (default: HS256)
ALGORITHM=HS256

# Access token expiry in minutes (default: 30)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token expiry in days (default: 7)
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── APPLICATION SETTINGS ─────────────────────────────────────────────────────

# Environment: "development" enables SQL echo logging, "production" disables it
ENVIRONMENT=development

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Hour (24h format, PKT) to run the nightly data pipeline
NIGHTLY_PIPELINE_HOUR=20

# Comma-separated list of PSX tickers to monitor
PSX_TICKERS=ENGRO,LUCK,OGDC,PPL,MCB,HBL,UBL,MARI,PSO,MEBL

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# ── CELERY CONFIGURATION ─────────────────────────────────────────────────────

# Celery broker URL (Redis database 1)
CELERY_BROKER_URL=redis://localhost:6379/1

# Celery result backend URL (Redis database 2)
CELERY_RESULT_BACKEND=redis://localhost:6379/2
